[Unit]
Description=Control de prestamo (Flask app)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/prestamo-app
Environment="APP_PASSWORD=cambia-esta-clave"
Environment="SECRET_KEY=cambia-esta-clave-secreta"
ExecStart=/opt/prestamo-app/venv/bin/gunicorn -w 2 -b 127.0.0.1:8000 app:app
Restart=always

[Install]
WantedBy=multi-user.target
